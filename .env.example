# Supabase Project Settings > API で確認する。
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# サーバー専用。ブラウザや公開リポジトリには置かない。
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# AES-256-GCM用の32バイトBase64鍵。READMEのコマンドで生成する。
TOKEN_ENCRYPTION_KEY=YOUR_32_BYTE_BASE64_KEY

# サーバーがCanvasトークンを送信してよいホストを限定する。
CANVAS_ALLOWED_HOSTS=lms.keio.jp

# 疎通確認スクリプト専用。Webアプリの利用者トークンはDBへ暗号化保存する。
CANVAS_BASE_URL=https://lms.keio.jp
CANVAS_API_TOKEN=YOUR_CANVAS_API_TOKEN
